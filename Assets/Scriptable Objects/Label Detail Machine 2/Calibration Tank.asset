  m_Script: {fileID: 11500000, guid: b2da2dd5269cbbc49898722278a6311c, type: 3}
  m_Name: Calibration Tank
  m_EditorClassIdentifier: 
  componentName: Calibration Tank
  specifications: (Measurement Tank)
  description: "Collects and measures the fluid during calibration to verify the
    accuracy of the Unit Under Test (UUT).\n\nWater Flow Direction\n\na. Water is
    directed through valve #4 to the pressure transmitter (E+H Liquiphant FTL31),
    then passes through the strainer filter before entering the in-line pump (Grundfos
    UP20-45 N 150). The pump operates at a maximum capacity of 4 m\xB3/hr.\nb. The
    system pressure can be monitored on the pressure gauge located adjacent to the
    inline pump. Subsequently, water is routed through the valve selected via the
    control panel.\nc. Water then flows through the E+H Prosonic Flow 92 flow meter,
    which records the flow rate, before being directed to the second tank via valve
    #10."
