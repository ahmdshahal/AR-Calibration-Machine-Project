  m_Script: {fileID: 11500000, guid: 0958c0d04b14c0e46b22c6b46dd90226, type: 3}
  m_Name: Step 6
  m_EditorClassIdentifier: 
  stepNumber: 6
  stepTitle: Tank System Operation
  stepDescription: "The level rig consists of two tanks:\r\n\u2022 Storage Tank (source
    tank)\r\n\u2022 Calibration Tank (measurement tank)\n\r\nOperation Logic:\r\nAt
    0% level setpoint:\r\no No water flows from the storage tank to the calibration
    tank.\n\r\nAt 25%, 50%, 75%, and 100% setpoints:\r\no Water flows from the storage
    tank into the calibration tank.\r\no The inflow continues until the target level
    (%) is achieved in the calibration tank."
