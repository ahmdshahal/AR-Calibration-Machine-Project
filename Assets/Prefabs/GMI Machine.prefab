  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Water Return Direction\n\na. Water will flow from the second tank to the
    first tank through Valve 11, passing through the E+H Liquiphant FTL31 Pressure
    Transmi\u01A9er. This transmi\u01A9er measures the water\npressure in the pipeline.\nb.
    The water then passes through a strainer filter before being pumped back via
    the Grundfos UP20-45 N 150 in-line pump. The flow rate can be adjusted using
    the Arita 1\u201D Gate Valve located downstream of the pump.\nc. Subsequently,
    the water flows through the Arita-107 SE Pressure Relief Valve. Should the pipeline
    pressure exceed 150 psi, the valve diverts water to the balancing pipe to safely
    reduce the pressure.\nd. Finally, the water passes through a check valve before
    re-entering the first tank via Valve 3. This check valve ensures unidirec\u019Fonal
    flow, preven\u019Fng backflow within the system.."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
